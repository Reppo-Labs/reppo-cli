{
  "name": "@reppo-labs/cli",
  "version": "0.1.0-alpha.0",
  "description": "Command-line interface for Reppo — mint pods, vote, lock REPPO, manage datanets. Built for AI agents.",
  "license": "MIT",
  "author": "Reppo Labs",
  "homepage": "https://github.com/Reppo-Labs/reppo-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Reppo-Labs/reppo-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Reppo-Labs/reppo-cli/issues"
  },
  "keywords": [
    "reppo",
    "cli",
    "base",
    "agents",
    "web3",
    "datanet"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "reppo": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/bin.ts",
    "lint": "echo 'eslint config not yet added; skipping' && exit 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "clipanion": "^4.0.0-rc.4",
    "proper-lockfile": "^4.1.2",
    "typanion": "^3.14.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0"
  }
}
